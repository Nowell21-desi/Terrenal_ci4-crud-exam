# CodeIgniter 4 specific
writable/cache/*
writable/logs/*
writable/session/*
writable/uploads/*
!writable/cache/index.html
!writable/logs/index.html
!writable/session/index.html
!writable/uploads/index.html

# Environment files
.env
.env.backup

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Composer
vendor/
composer.lock

# Node modules
node_modules/

# Build files
public/build/
